# LLM Provider — set the key(s) for whichever provider(s) you'll use; ACTIVE_LLM controls which is active
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GROQ_API_KEY=gsk_...

# "groq", "anthropic", or "openai" — matches config.py's actual supported values
ACTIVE_LLM=groq

# Model names
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_MODEL=gpt-4o-mini
GROQ_MODEL=llama-3.3-70b-versatile

# Embeddings — "local" (sentence-transformers, free, no API key, recommended
# for the prototype) or "openai" (text-embedding-3-small, costs money).
# config.py already defaults to "local" — this was previously out of sync
# with that default and said "always OpenAI", which was wrong.
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ChromaDB
CHROMA_PERSIST_DIR=./data/chroma

# Stage 4 experiment mode: "semantic" | "llm" | "both"
SIMILARITY_MODE=both

# Persistence (M1 — new)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# App
LOG_LEVEL=INFO
MAX_RESUME_SIZE_MB=10
